{
  "name": "discovery-quest",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Discovery Quest — open learning engine, course format, and official courses.",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "preview:space": "npm --workspace space-preview run dev",
    "course:check": "node scripts/course-check.mjs",
    "course:export": "node scripts/export-course.mjs",
    "course:capabilities": "node scripts/gen-capabilities.mjs",
    "course:schema": "node scripts/gen-schema.mjs",
    "course:changelog": "node scripts/gen-changelog.mjs",
    "validate": "node scripts/gen-capabilities.mjs --check && node scripts/gen-schema.mjs --check && node scripts/gen-changelog.mjs --check",
    "voice:space": "node packages/space/scripts/gen-voice.mjs",
    "tutorial:space": "node packages/space/scripts/record-tutorial.mjs",
    "course:check:space": "node scripts/course-check.mjs packages/space/space.course.yml --app packages/space --voice examples/space-preview"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "js-yaml": "^4.2.0"
  },
  "overrides": {
    "framer-motion": "11.18.2"
  },
  "dependencies": {
    "framer-motion": "11.18.2"
  }
}
