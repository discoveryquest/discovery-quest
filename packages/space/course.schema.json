{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://discoveryquest.app/schema/space/course.schema.json",
  "title": "Discovery Quest course — space",
  "$comment": "GENERATED from engine.capabilities.json v2 by gen-schema.mjs. Do not edit by hand.",
  "type": "object",
  "required": [
    "course"
  ],
  "properties": {
    "course": {
      "$ref": "#/$defs/course"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "course": {
      "type": "object",
      "required": [
        "formatVersion",
        "id",
        "title",
        "subject",
        "worlds"
      ],
      "properties": {
        "formatVersion": {
          "type": "integer"
        },
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        },
        "companion": {
          "type": "string"
        },
        "voice": {
          "type": "object"
        },
        "engine": {
          "type": "string"
        },
        "lowercase": {
          "type": "boolean"
        },
        "ui": {
          "type": "object"
        },
        "reactions": {
          "type": "object"
        },
        "worlds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/world"
          }
        },
        "lessons": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/lesson"
          }
        },
        "narration": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "content": {
          "type": "object",
          "properties": {
            "questions": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "question": {
                    "type": "string"
                  },
                  "answer": {
                    "type": "string"
                  },
                  "distractors": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "band": {
                    "type": "number"
                  }
                },
                "required": [
                  "question",
                  "answer",
                  "distractors",
                  "band"
                ],
                "additionalProperties": false
              }
            },
            "practice": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "station": {
                    "type": "string"
                  },
                  "band": {
                    "type": "number"
                  },
                  "kind": {
                    "type": "string"
                  },
                  "say": {
                    "type": "string"
                  },
                  "prompt": {
                    "type": "string"
                  },
                  "scene": {
                    "type": [
                      "object",
                      "null"
                    ]
                  },
                  "target": {
                    "type": "object"
                  },
                  "feedback": {
                    "type": [
                      "object",
                      "null"
                    ]
                  }
                },
                "required": [
                  "station",
                  "band",
                  "kind",
                  "say",
                  "prompt",
                  "target"
                ],
                "additionalProperties": false
              }
            }
          }
        }
      }
    },
    "world": {
      "type": "object",
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "emoji": {
          "type": "string"
        },
        "color": {
          "type": "string"
        },
        "blurb": {
          "type": "string"
        },
        "soon": {
          "type": "boolean"
        },
        "stations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/station"
          }
        }
      }
    },
    "station": {
      "type": "object",
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "sub": {
          "type": "string"
        },
        "board": {
          "enum": [
            "quiz",
            "practice"
          ]
        },
        "bands": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "minItems": 1
        },
        "lesson": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "concept": {
          "type": "string"
        },
        "soon": {
          "type": "boolean"
        }
      },
      "if": {
        "properties": {
          "soon": {
            "const": true
          }
        },
        "required": [
          "soon"
        ]
      },
      "then": true,
      "else": {
        "required": [
          "board",
          "bands"
        ]
      }
    },
    "lesson": {
      "type": "object",
      "required": [
        "title",
        "sections"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/section"
          }
        }
      }
    },
    "section": {
      "type": "object",
      "required": [
        "id",
        "beats"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "beats": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/beat"
          }
        }
      }
    },
    "beat": {
      "type": "object",
      "required": [
        "say",
        "caption",
        "view"
      ],
      "properties": {
        "say": {
          "type": "string"
        },
        "caption": {
          "type": "string"
        },
        "advance": {
          "type": [
            "string",
            "number"
          ]
        },
        "view": {
          "$ref": "#/$defs/view"
        }
      }
    },
    "view": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "enum": [
            "fact",
            "body",
            "orbit",
            "field",
            "launch",
            "compare",
            "spin",
            "seasons",
            "fall",
            "scrub",
            "reveal",
            "moonPhase"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "fact"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "kind": {
                "const": "fact"
              },
              "key": {
                "type": [
                  "string",
                  "number"
                ]
              },
              "emoji": {
                "type": "string"
              },
              "text": {
                "type": "string"
              }
            },
            "required": [
              "kind",
              "emoji",
              "text"
            ],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "body"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "kind": {
                "const": "body"
              },
              "key": {
                "type": [
                  "string",
                  "number"
                ]
              },
              "body": {
                "type": "object",
                "description": "{ role: star|planet|moon|blackhole, color?, rings?(bool|deg), tilt?(deg), glow?(bool), phase?(0..1 lit fraction for a moon) }"
              },
              "label": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "caption under the body"
              }
            },
            "required": [
              "kind",
              "body"
            ],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "orbit"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "kind": {
                "const": "orbit"
              },
              "key": {
                "type": [
                  "string",
                  "number"
                ]
              },
              "bodies": {
                "type": "array",
                "items": {
                  "type": "object"
                },
                "description": "each { id, role, orbits?(id of body it circles), radius?, period?(seconds), phaseLit?(bool) }"
              }
            },
            "required": [
              "kind",
              "bodies"
            ],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "field"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "kind": {
                "const": "field"
              },
              "key": {
                "type": [
                  "string",
                  "number"
                ]
              },
              "tint": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "backdrop tint, e.g. nebula | deep-space (default)"
              },
              "density": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "low | medium (default) | high"
              },
              "label": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "kind"
            ],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "launch"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "kind": {
                "const": "launch"
              },
              "key": {
                "type": [
                  "string",
                  "number"
                ]
              },
              "payload": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "optional emoji/label riding the rocket"
              }
            },
            "required": [
              "kind"
            ],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "compare"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "kind": {
                "const": "compare"
              },
              "key": {
                "type": [
                  "string",
                  "number"
                ]
              },
              "items": {
                "type": "array",
                "items": {
                  "type": "object"
                },
                "description": "each { label, relSize(0..1 of the largest), color? }"
              }
            },
            "required": [
              "kind",
              "items"
            ],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "spin"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "kind": {
                "const": "spin"
              },
              "key": {
                "type": [
                  "string",
                  "number"
                ]
              },
              "fraction": {
                "type": [
                  "number",
                  "null"
                ],
                "description": "0..1 spin position (0=dawn, 1/3=noon, 2/3=dusk, 1=night); injected automatically when used as a scrub base"
              },
              "markerLabel": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "label on the surface marker riding the spin (default YOU)"
              }
            },
            "required": [
              "kind"
            ],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "seasons"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "kind": {
                "const": "seasons"
              },
              "key": {
                "type": [
                  "string",
                  "number"
                ]
              },
              "fraction": {
                "type": [
                  "number",
                  "null"
                ],
                "description": "0..1 orbit position (0=spring/top, 1/3=summer/right, 2/3=autumn/bottom, 1=winter/left); injected automatically when used as a scrub base"
              }
            },
            "required": [
              "kind"
            ],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "fall"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "kind": {
                "const": "fall"
              },
              "key": {
                "type": [
                  "string",
                  "number"
                ]
              },
              "items": {
                "type": [
                  "array",
                  "null"
                ],
                "items": {
                  "type": "object"
                },
                "description": "each { label, emoji, g } where g is surface gravity relative to Earth; defaults to Jupiter 2.5 / Earth 1 / Moon 0.17"
              }
            },
            "required": [
              "kind"
            ],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "scrub"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "kind": {
                "const": "scrub"
              },
              "key": {
                "type": [
                  "string",
                  "number"
                ]
              },
              "base": {
                "type": [
                  "object",
                  "null"
                ],
                "description": "an underlying scene descriptor (e.g. { kind: orbit, bodies: [...] }) the interaction renders on"
              },
              "states": {
                "type": "array",
                "items": {
                  "type": "object"
                },
                "description": "ordered { id, label, say, caption }; each `say` must exist in narration"
              }
            },
            "required": [
              "kind",
              "states"
            ],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "reveal"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "kind": {
                "const": "reveal"
              },
              "key": {
                "type": [
                  "string",
                  "number"
                ]
              },
              "base": {
                "type": [
                  "object",
                  "null"
                ],
                "description": "an underlying scene descriptor (e.g. { kind: field, tint: nebula }) the hotspots sit on"
              },
              "hotspots": {
                "type": "array",
                "items": {
                  "type": "object"
                },
                "description": "each { id, label, say, caption, x?, y?(percent positions) }; each `say` must exist in narration"
              }
            },
            "required": [
              "kind",
              "hotspots"
            ],
            "additionalProperties": false
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "moonPhase"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "kind": {
                "const": "moonPhase"
              },
              "key": {
                "type": [
                  "string",
                  "number"
                ]
              },
              "variant": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "diagram (default) | strip"
              },
              "active": {
                "type": [
                  "integer",
                  "null"
                ],
                "description": "strip variant only: index 0..7 of the phase to statically highlight (lesson engine drives one per beat); -1 = all phases shown with no highlight. When set it overrides the auto-cycle and narrated tour and ignores `says`."
              },
              "interactive": {
                "type": [
                  "boolean",
                  "null"
                ],
                "description": "false (default) = auto-orbiting animation; true = learner drags a slider to explore all phases (diagram variant only)"
              },
              "says": {
                "type": [
                  "object",
                  "null"
                ],
                "description": "{ new, waxingCrescent, first, waxingGibbous, full, waningGibbous, last, waningCrescent } narration keys; in diagram+interactive they're spoken when the slider enters each named phase, in strip (without `active`) they drive the audio-paced narrated tour"
              }
            },
            "required": [
              "kind"
            ],
            "additionalProperties": false
          }
        }
      ]
    }
  }
}
